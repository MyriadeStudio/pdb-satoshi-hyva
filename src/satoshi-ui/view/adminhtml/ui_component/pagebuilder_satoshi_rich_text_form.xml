<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd" extends="pagebuilder_base_form">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">pagebuilder_satoshi_rich_text_form.pagebuilder_satoshi_rich_text_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Rich text</item>
    </argument>
    <settings>
        <deps>
            <dep>pagebuilder_satoshi_rich_text_form.pagebuilder_satoshi_rich_text_form_data_source</dep>
        </deps>
        <namespace>pagebuilder_satoshi_rich_text_form</namespace>
    </settings>
    <dataSource name="pagebuilder_satoshi_rich_text_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_PageBuilder/js/form/provider</item>
            </item>
        </argument>
        <dataProvider name="pagebuilder_satoshi_rich_text_form_data_source" class="Magento\PageBuilder\Model\ContentType\DataProvider">
            <settings>
                <requestFieldName/>
                <primaryFieldName/>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="appearance_fieldset" sortOrder="10" component="Magento_PageBuilder/js/form/element/dependent-fieldset">
        <settings>
            <label translate="true">Appearance</label>
            <additionalClasses>
                <class name="admin__fieldset-visual-select-large">true</class>
            </additionalClasses>
            <collapsible>false</collapsible>
            <opened>true</opened>
            <imports>
                <link name="hideFieldset">${$.name}.appearance:options</link>
                <link name="hideLabel">${$.name}.appearance:options</link>
            </imports>
        </settings>
        <field name="appearance" formElement="select" sortOrder="10" component="Magento_PageBuilder/js/form/element/dependent-visual-select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">default</item>
                </item>
            </argument>
            <settings>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                    <class name="admin__field-visual-select-container">true</class>
                </additionalClasses>
                <dataType>text</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <elementTmpl>Magento_PageBuilder/form/element/visual-select</elementTmpl>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="AppearanceSourceSatoshi"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>

    <fieldset name="general" sortOrder="20">
        <settings>
            <label />
        </settings>

        <!-- Heading field -->
        <field name="heading" sortOrder="10" formElement="input">
            <settings>
                <label translate="true">Heading</label>
                <dataType>text</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-string" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <!-- Caption field -->
        <field name="caption" sortOrder="20" formElement="textarea">
            <settings>
                <label translate="true">Caption</label>
                <dataType>text</dataType>
                <validation>
                    <rule name="validate-string" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <!-- Description field -->
        <field name="content" sortOrder="30" formElement="wysiwyg" template="ui/form/field">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">page</item>
                    <item name="wysiwygConfigData" xsi:type="array">
                        <item name="pagebuilder_button" xsi:type="boolean">false</item>
                        <item name="is_pagebuilder_enabled" xsi:type="boolean">false</item>
                        <item name="toggle_button" xsi:type="boolean">false</item>
                        <item name="height" xsi:type="string">200px</item>
                    </item>
                </item>
            </argument>
            <settings>
                <label translate="true">Content</label>
                <dataScope>content</dataScope>
                <validation>
                    <rule name="validate-no-url" xsi:type="boolean">true</rule>
                    <rule name="validate-no-widget" xsi:type="boolean">true</rule>
                </validation>
                <imports>
                    <link name="validation.validate-no-url">${$.parentName}.link_url:value</link>
                    <link name="validation.validate-no-widget">${$.parentName}.link_url:value</link>
                </imports>
            </settings>
            <formElements>
                <wysiwyg>
                    <settings>
                        <wysiwyg>true</wysiwyg>
                    </settings>
                </wysiwyg>
            </formElements>
        </field>


        <!-- Button, label and url field -->
        <field name="button_label" sortOrder="40" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="fit" xsi:type="boolean">false</item>
                </item>
            </argument>
            <settings>
                <label>Button label</label>
                <dataType>text</dataType>
                <validation>
                    <rule name="validate-no-html-tags" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <urlInput name="button_link" sortOrder="50" template="Magento_PageBuilder/form/element/url-input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Button link</label>
                <dataScope>button_link</dataScope>
                <urlTypes class="Magento\Ui\Model\UrlInput\LinksConfigProvider"/>
                <validation>
                    <rule name="validate-message-no-link" xsi:type="boolean">true</rule>
                    <rule name="validate-message-no-widget" xsi:type="boolean">true</rule>
                </validation>
                <imports>
                    <link name="validation.validate-message-no-link">${$.parentName}.message:value</link>
                    <link name="validation.validate-message-no-widget">${$.parentName}.message:value</link>
                </imports>
            </settings>
        </urlInput>

    </fieldset>

    <fieldset name="style" sortOrder="25">
        <settings>
            <label translate="true">Style</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>

        <field name="text_color_scheme" sortOrder="10" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">default</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Text color scheme</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
                <notice translate="true">Couleur des textes : « Par défaut » = suit le fond de page, « Inversé » = ton opposé (fond sombre).</notice>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">default</item>
                                <item name="label" xsi:type="string" translate="true">Par défaut — texte qui suit le fond</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">inverse</item>
                                <item name="label" xsi:type="string" translate="true">Inversé — texte sur média contrastant</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>

    <!-- PDB — onglet Animation au scroll (data-pdb-anim*). Observer global Pdb_ThemeHyva/js/pdb-animations.js -->
    <fieldset name="pdb_animation" sortOrder="25">
        <settings>
            <label translate="true">Animation</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="pdb_anim" sortOrder="10" formElement="select">
            <argument name="data" xsi:type="array"><item name="config" xsi:type="array"><item name="default" xsi:type="string"></item></item></argument>
            <settings><label translate="true">Animation au scroll</label><dataType>text</dataType><dataScope>pdb_anim</dataScope>
                <notice translate="true">Déclenchée à l'entrée dans le viewport. Sans effet au-dessus de la ligne de flottaison.</notice></settings>
            <formElements><select><settings><options>
                <option name="none" xsi:type="array"><item name="value" xsi:type="string"></item><item name="label" xsi:type="string" translate="true">Aucune</item></option>
                <option name="fade_in" xsi:type="array"><item name="value" xsi:type="string">fade-in</item><item name="label" xsi:type="string" translate="true">Fondu (fade-in)</item></option>
                <option name="fade_up" xsi:type="array"><item name="value" xsi:type="string">fade-up</item><item name="label" xsi:type="string" translate="true">Fondu + montée (fade-up)</item></option>
                <option name="fade_down" xsi:type="array"><item name="value" xsi:type="string">fade-down</item><item name="label" xsi:type="string" translate="true">Fondu + descente (fade-down)</item></option>
                <option name="slide_left" xsi:type="array"><item name="value" xsi:type="string">slide-left</item><item name="label" xsi:type="string" translate="true">Glissement depuis la droite (slide-left)</item></option>
                <option name="slide_right" xsi:type="array"><item name="value" xsi:type="string">slide-right</item><item name="label" xsi:type="string" translate="true">Glissement depuis la gauche (slide-right)</item></option>
                <option name="zoom" xsi:type="array"><item name="value" xsi:type="string">zoom</item><item name="label" xsi:type="string" translate="true">Zoom</item></option>
                <option name="blur_in" xsi:type="array"><item name="value" xsi:type="string">blur-in</item><item name="label" xsi:type="string" translate="true">Netteté (blur-in)</item></option>
            </options></settings></select></formElements>
        </field>
        <field name="pdb_anim_duration" sortOrder="20" formElement="select">
            <argument name="data" xsi:type="array"><item name="config" xsi:type="array"><item name="default" xsi:type="string"></item></item></argument>
            <settings><label translate="true">Durée (ms)</label><dataType>text</dataType><dataScope>pdb_anim_duration</dataScope></settings>
            <formElements><select><settings><options>
                <option name="def" xsi:type="array"><item name="value" xsi:type="string"></item><item name="label" xsi:type="string" translate="true">Défaut (600)</item></option>
                <option name="d300" xsi:type="array"><item name="value" xsi:type="string">300</item><item name="label" xsi:type="string">300</item></option>
                <option name="d450" xsi:type="array"><item name="value" xsi:type="string">450</item><item name="label" xsi:type="string">450</item></option>
                <option name="d600" xsi:type="array"><item name="value" xsi:type="string">600</item><item name="label" xsi:type="string">600</item></option>
                <option name="d800" xsi:type="array"><item name="value" xsi:type="string">800</item><item name="label" xsi:type="string">800</item></option>
                <option name="d1000" xsi:type="array"><item name="value" xsi:type="string">1000</item><item name="label" xsi:type="string">1000</item></option>
            </options></settings></select></formElements>
        </field>
        <field name="pdb_anim_delay" sortOrder="30" formElement="select">
            <argument name="data" xsi:type="array"><item name="config" xsi:type="array"><item name="default" xsi:type="string"></item></item></argument>
            <settings><label translate="true">Délai (ms)</label><dataType>text</dataType><dataScope>pdb_anim_delay</dataScope></settings>
            <formElements><select><settings><options>
                <option name="def" xsi:type="array"><item name="value" xsi:type="string"></item><item name="label" xsi:type="string" translate="true">Aucun</item></option>
                <option name="delay100" xsi:type="array"><item name="value" xsi:type="string">100</item><item name="label" xsi:type="string">100</item></option>
                <option name="delay200" xsi:type="array"><item name="value" xsi:type="string">200</item><item name="label" xsi:type="string">200</item></option>
                <option name="delay300" xsi:type="array"><item name="value" xsi:type="string">300</item><item name="label" xsi:type="string">300</item></option>
                <option name="delay500" xsi:type="array"><item name="value" xsi:type="string">500</item><item name="label" xsi:type="string">500</item></option>
            </options></settings></select></formElements>
        </field>
    </fieldset>
</form>
