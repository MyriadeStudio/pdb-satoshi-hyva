<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd" extends="pagebuilder_base_form">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">pagebuilder_satoshi_guarantees_form.pagebuilder_satoshi_guarantees_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Guarantees</item>
    </argument>
    <settings>
        <deps>
            <dep>pagebuilder_satoshi_guarantees_form.pagebuilder_satoshi_guarantees_form_data_source</dep>
        </deps>
        <namespace>pagebuilder_satoshi_guarantees_form</namespace>
    </settings>
    <dataSource name="pagebuilder_satoshi_guarantees_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_PageBuilder/js/form/provider</item>
            </item>
        </argument>
        <dataProvider name="pagebuilder_satoshi_guarantees_form_data_source" class="Magento\PageBuilder\Model\ContentType\DataProvider">
            <settings>
                <requestFieldName/>
                <primaryFieldName/>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="appearance_fieldset" sortOrder="10" component="Magento_PageBuilder/js/form/element/dependent-fieldset">
        <settings>
            <label translate="true">Appearance</label>
            <additionalClasses>
                <class name="admin__fieldset-visual-select-large">true</class>
            </additionalClasses>
            <collapsible>false</collapsible>
            <opened>true</opened>
            <imports>
                <link name="hideFieldset">${$.name}.appearance:options</link>
                <link name="hideLabel">${$.name}.appearance:options</link>
            </imports>
        </settings>
        <field name="appearance" formElement="select" sortOrder="10" component="Magento_PageBuilder/js/form/element/dependent-visual-select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">default</item>
                </item>
            </argument>
            <settings>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                    <class name="admin__field-visual-select-container">true</class>
                </additionalClasses>
                <dataType>text</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <elementTmpl>Magento_PageBuilder/form/element/visual-select</elementTmpl>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="AppearanceSourceSatoshi"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>

    <fieldset name="general" sortOrder="20">
        <settings>
            <label translate="true">Columns</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>

        <dynamicRows name="guarantees_columns">
            <settings>
                <addButtonLabel translate="true">Add Column</addButtonLabel>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                </additionalClasses>
                <dndConfig>
                    <param name="enabled" xsi:type="boolean">false</param>
                </dndConfig>
                <componentType>dynamicRows</componentType>
            </settings>
            <container name="record" component="Magento_Ui/js/dynamic-rows/record">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="isTemplate" xsi:type="boolean">true</item>
                        <item name="is_collection" xsi:type="boolean">true</item>
                        <item name="componentType" xsi:type="string">container</item>
                    </item>
                </argument>
                <field name="column_icon" sortOrder="10" formElement="select">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="component" xsi:type="string">Pdb_ThemeHyva/js/form/element/icon-select</item>
                            <item name="elementTmpl" xsi:type="string">Pdb_ThemeHyva/form/element/icon-select</item>
                            <item name="optionsUrl" xsi:type="url" path="pdb_themehyva/icon/options"/>
                            <item name="default" xsi:type="string">lucide:shield-check</item>
                        </item>
                    </argument>
                    <settings>
                        <label translate="true">Column icon</label>
                        <dataType>text</dataType>
                    </settings>
                </field>
                <field name="column_title" sortOrder="20" formElement="input">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="source" xsi:type="string">page</item>
                        </item>
                    </argument>
                    <settings>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                            <rule name="validate-no-html-tags" xsi:type="boolean">true</rule>
                        </validation>
                        <dataType>text</dataType>
                        <label translate="true">Title</label>
                    </settings>
                </field>
                <field name="column_description" sortOrder="30" formElement="textarea">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="source" xsi:type="string">page</item>
                        </item>
                    </argument>
                    <settings>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                        </validation>
                        <dataType>text</dataType>
                        <label translate="true">Description</label>
                    </settings>
                </field>
                <actionDelete template="Magento_Backend/dynamic-rows/cells/action-delete">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="fit" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>text</dataType>
                        <label>Delete</label>
                        <componentType>actionDelete</componentType>
                    </settings>
                </actionDelete>
            </container>
        </dynamicRows>
    </fieldset>

    <fieldset name="style_fieldset" sortOrder="30">
        <settings>
            <label translate="true">Style</label>
            <collapsible>true</collapsible>
            <opened>false</opened>
        </settings>

        <field name="icon_style" sortOrder="10" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">bordered</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Icon style</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">bordered</item>
                                <item name="label" xsi:type="string" translate="true">Icône entourée d'une bordure (cercle)</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">filled</item>
                                <item name="label" xsi:type="string" translate="true">Icône dans un cercle avec fond</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">bare</item>
                                <item name="label" xsi:type="string" translate="true">Icône seule</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="icon_size" sortOrder="15" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">medium</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Icon size</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">small</item>
                                <item name="label" xsi:type="string" translate="true">Small</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">medium</item>
                                <item name="label" xsi:type="string" translate="true">Medium</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">large</item>
                                <item name="label" xsi:type="string" translate="true">Large</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="layout" sortOrder="18" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">stacked</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Layout</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">stacked</item>
                                <item name="label" xsi:type="string" translate="true">Icône au-dessus, texte en dessous</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">inline</item>
                                <item name="label" xsi:type="string" translate="true">Icône à gauche, texte à droite</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="icon_color" sortOrder="20" formElement="select">
            <settings>
                <label translate="true">Icon color</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Pdb\ThemeHyva\Model\Adminhtml\Source\DesignColors"/>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="circle_color" sortOrder="30" formElement="select">
            <settings>
                <label translate="true">Circle color (border / background)</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Pdb\ThemeHyva\Model\Adminhtml\Source\DesignColors"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>

    <fieldset name="advanced">
        <field name="text_align">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                </item>
            </argument>
        </field>
    </fieldset>
</form>
