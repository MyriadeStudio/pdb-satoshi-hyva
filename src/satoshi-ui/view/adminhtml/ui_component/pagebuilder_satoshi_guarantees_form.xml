<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd" extends="pagebuilder_base_form">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">pagebuilder_satoshi_guarantees_form.pagebuilder_satoshi_guarantees_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Guarantees</item>
    </argument>
    <settings>
        <deps>
            <dep>pagebuilder_satoshi_guarantees_form.pagebuilder_satoshi_guarantees_form_data_source</dep>
        </deps>
        <namespace>pagebuilder_satoshi_guarantees_form</namespace>
    </settings>
    <dataSource name="pagebuilder_satoshi_guarantees_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_PageBuilder/js/form/provider</item>
            </item>
        </argument>
        <dataProvider name="pagebuilder_satoshi_guarantees_form_data_source" class="Magento\PageBuilder\Model\ContentType\DataProvider">
            <settings>
                <requestFieldName/>
                <primaryFieldName/>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="appearance_fieldset" sortOrder="10" component="Magento_PageBuilder/js/form/element/dependent-fieldset">
        <settings>
            <label translate="true">Appearance</label>
            <additionalClasses>
                <class name="admin__fieldset-visual-select-large">true</class>
            </additionalClasses>
            <collapsible>false</collapsible>
            <opened>true</opened>
            <imports>
                <link name="hideFieldset">${$.name}.appearance:options</link>
                <link name="hideLabel">${$.name}.appearance:options</link>
            </imports>
        </settings>
        <field name="appearance" formElement="select" sortOrder="10" component="Magento_PageBuilder/js/form/element/dependent-visual-select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">default</item>
                </item>
            </argument>
            <settings>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                    <class name="admin__field-visual-select-container">true</class>
                </additionalClasses>
                <dataType>text</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <elementTmpl>Magento_PageBuilder/form/element/visual-select</elementTmpl>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="AppearanceSourceSatoshi"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>

    <fieldset name="general" sortOrder="20">
        <settings>
            <label translate="true">Columns</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>

        <dynamicRows name="guarantees_columns">
            <settings>
                <addButtonLabel translate="true">Add Column</addButtonLabel>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                </additionalClasses>
                <dndConfig>
                    <param name="enabled" xsi:type="boolean">false</param>
                </dndConfig>
                <componentType>dynamicRows</componentType>
            </settings>
            <container name="record" component="Magento_Ui/js/dynamic-rows/record">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="isTemplate" xsi:type="boolean">true</item>
                        <item name="is_collection" xsi:type="boolean">true</item>
                        <item name="componentType" xsi:type="string">container</item>
                    </item>
                </argument>
                <field name="column_icon" sortOrder="10" formElement="select">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="component" xsi:type="string">Pdb_ThemeHyva/js/form/element/icon-select</item>
                            <item name="elementTmpl" xsi:type="string">Pdb_ThemeHyva/form/element/icon-select</item>
                            <item name="optionsUrl" xsi:type="url" path="pdb_themehyva/icon/options"/>
                            <item name="default" xsi:type="string">lucide:shield-check</item>
                        </item>
                    </argument>
                    <settings>
                        <label translate="true">Column icon</label>
                        <dataType>text</dataType>
                    </settings>
                </field>
                <field name="column_title" sortOrder="20" formElement="input">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="source" xsi:type="string">page</item>
                        </item>
                    </argument>
                    <settings>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                            <rule name="validate-no-html-tags" xsi:type="boolean">true</rule>
                        </validation>
                        <dataType>text</dataType>
                        <label translate="true">Title</label>
                    </settings>
                </field>
                <field name="column_description" sortOrder="30" formElement="textarea">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="source" xsi:type="string">page</item>
                        </item>
                    </argument>
                    <settings>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                        </validation>
                        <dataType>text</dataType>
                        <label translate="true">Description</label>
                    </settings>
                </field>
                <field name="column_link" sortOrder="35" formElement="input">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="source" xsi:type="string">page</item>
                        </item>
                    </argument>
                    <settings>
                        <!-- Champ optionnel. Pas de regle validate-url native (elle exige un protocole
                             et rejette les chemins relatifs) : on autorise URL absolue ou relative
                             (ex. /livraison). Si renseigne, toute la colonne devient cliquable. -->
                        <dataType>text</dataType>
                        <label translate="true">Link URL (optional)</label>
                        <notice translate="true">URL absolue (https://…) ou relative (/livraison). Si renseigné, toute la colonne (icône + titre + description) devient cliquable.</notice>
                    </settings>
                </field>
                <field name="column_link_new_tab" sortOrder="36" formElement="checkbox">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">false</item>
                        </item>
                    </argument>
                    <settings>
                        <label translate="true">Open link in a new tab</label>
                        <dataType>boolean</dataType>
                        <dataScope>column_link_new_tab</dataScope>
                    </settings>
                    <formElements>
                        <checkbox>
                            <settings>
                                <valueMap>
                                    <map name="false" xsi:type="string">false</map>
                                    <map name="true" xsi:type="string">true</map>
                                </valueMap>
                                <prefer>toggle</prefer>
                            </settings>
                        </checkbox>
                    </formElements>
                </field>
                <actionDelete template="Magento_Backend/dynamic-rows/cells/action-delete">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="fit" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>text</dataType>
                        <label>Delete</label>
                        <componentType>actionDelete</componentType>
                    </settings>
                </actionDelete>
            </container>
        </dynamicRows>
    </fieldset>

    <fieldset name="style_fieldset" sortOrder="30">
        <settings>
            <label translate="true">Style</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>

        <field name="text_color_scheme" sortOrder="5" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">default</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Text color scheme</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
                <notice translate="true">Couleur des textes (titre + description) : « Par défaut » = suit le fond de page, « Inversé » = ton opposé (fond sombre).</notice>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">default</item>
                                <item name="label" xsi:type="string" translate="true">Par défaut — texte qui suit le fond</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">inverse</item>
                                <item name="label" xsi:type="string" translate="true">Inversé — texte sur média contrastant</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="icon_style" sortOrder="10" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">bordered</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Icon style</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">bordered</item>
                                <item name="label" xsi:type="string" translate="true">Icône entourée d'une bordure (cercle)</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">filled</item>
                                <item name="label" xsi:type="string" translate="true">Icône dans un cercle avec fond</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">bare</item>
                                <item name="label" xsi:type="string" translate="true">Icône seule</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="icon_size" sortOrder="15" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">medium</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Icon size</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">small</item>
                                <item name="label" xsi:type="string" translate="true">Small</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">medium</item>
                                <item name="label" xsi:type="string" translate="true">Medium</item>
                            </option>
                            <option name="2" xsi:type="array">
                                <item name="value" xsi:type="string">large</item>
                                <item name="label" xsi:type="string" translate="true">Large</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="layout" sortOrder="18" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">stacked</item>
                </item>
            </argument>
            <settings>
                <label translate="true">Layout</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">stacked</item>
                                <item name="label" xsi:type="string" translate="true">Icône au-dessus, texte en dessous</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">inline</item>
                                <item name="label" xsi:type="string" translate="true">Icône à gauche, texte à droite</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="icon_color" sortOrder="20" formElement="select">
            <settings>
                <label translate="true">Icon color</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Pdb\ThemeHyva\Model\Adminhtml\Source\DesignColors"/>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="circle_color" sortOrder="30" formElement="select">
            <settings>
                <label translate="true">Circle color (border / background)</label>
                <dataType>text</dataType>
                <additionalClasses>
                    <class name="admin__field-medium">true</class>
                </additionalClasses>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Pdb\ThemeHyva\Model\Adminhtml\Source\DesignColors"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>

    <fieldset name="advanced">
        <field name="text_align">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                </item>
            </argument>
        </field>
    </fieldset>
    <!-- PDB — onglet Animation au scroll (data-pdb-anim*). Observer global Pdb_ThemeHyva/js/pdb-animations.js -->
    <fieldset name="pdb_animation" sortOrder="25">
        <settings>
            <label translate="true">Animation</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="pdb_anim" sortOrder="10" formElement="select">
            <argument name="data" xsi:type="array"><item name="config" xsi:type="array"><item name="default" xsi:type="string"></item></item></argument>
            <settings><label translate="true">Animation au scroll</label><dataType>text</dataType><dataScope>pdb_anim</dataScope>
                <notice translate="true">Déclenchée à l'entrée dans le viewport. Sans effet au-dessus de la ligne de flottaison.</notice></settings>
            <formElements><select><settings><options>
                <option name="none" xsi:type="array"><item name="value" xsi:type="string"></item><item name="label" xsi:type="string" translate="true">Aucune</item></option>
                <option name="fade_in" xsi:type="array"><item name="value" xsi:type="string">fade-in</item><item name="label" xsi:type="string" translate="true">Fondu (fade-in)</item></option>
                <option name="fade_up" xsi:type="array"><item name="value" xsi:type="string">fade-up</item><item name="label" xsi:type="string" translate="true">Fondu + montée (fade-up)</item></option>
                <option name="fade_down" xsi:type="array"><item name="value" xsi:type="string">fade-down</item><item name="label" xsi:type="string" translate="true">Fondu + descente (fade-down)</item></option>
                <option name="slide_left" xsi:type="array"><item name="value" xsi:type="string">slide-left</item><item name="label" xsi:type="string" translate="true">Glissement depuis la droite (slide-left)</item></option>
                <option name="slide_right" xsi:type="array"><item name="value" xsi:type="string">slide-right</item><item name="label" xsi:type="string" translate="true">Glissement depuis la gauche (slide-right)</item></option>
                <option name="zoom" xsi:type="array"><item name="value" xsi:type="string">zoom</item><item name="label" xsi:type="string" translate="true">Zoom</item></option>
                <option name="blur_in" xsi:type="array"><item name="value" xsi:type="string">blur-in</item><item name="label" xsi:type="string" translate="true">Netteté (blur-in)</item></option>
            </options></settings></select></formElements>
        </field>
        <field name="pdb_anim_duration" sortOrder="20" formElement="select">
            <argument name="data" xsi:type="array"><item name="config" xsi:type="array"><item name="default" xsi:type="string"></item></item></argument>
            <settings><label translate="true">Durée (ms)</label><dataType>text</dataType><dataScope>pdb_anim_duration</dataScope></settings>
            <formElements><select><settings><options>
                <option name="def" xsi:type="array"><item name="value" xsi:type="string"></item><item name="label" xsi:type="string" translate="true">Défaut (600)</item></option>
                <option name="d300" xsi:type="array"><item name="value" xsi:type="string">300</item><item name="label" xsi:type="string">300</item></option>
                <option name="d450" xsi:type="array"><item name="value" xsi:type="string">450</item><item name="label" xsi:type="string">450</item></option>
                <option name="d600" xsi:type="array"><item name="value" xsi:type="string">600</item><item name="label" xsi:type="string">600</item></option>
                <option name="d800" xsi:type="array"><item name="value" xsi:type="string">800</item><item name="label" xsi:type="string">800</item></option>
                <option name="d1000" xsi:type="array"><item name="value" xsi:type="string">1000</item><item name="label" xsi:type="string">1000</item></option>
            </options></settings></select></formElements>
        </field>
        <field name="pdb_anim_delay" sortOrder="30" formElement="select">
            <argument name="data" xsi:type="array"><item name="config" xsi:type="array"><item name="default" xsi:type="string"></item></item></argument>
            <settings><label translate="true">Délai (ms)</label><dataType>text</dataType><dataScope>pdb_anim_delay</dataScope></settings>
            <formElements><select><settings><options>
                <option name="def" xsi:type="array"><item name="value" xsi:type="string"></item><item name="label" xsi:type="string" translate="true">Aucun</item></option>
                <option name="delay100" xsi:type="array"><item name="value" xsi:type="string">100</item><item name="label" xsi:type="string">100</item></option>
                <option name="delay200" xsi:type="array"><item name="value" xsi:type="string">200</item><item name="label" xsi:type="string">200</item></option>
                <option name="delay300" xsi:type="array"><item name="value" xsi:type="string">300</item><item name="label" xsi:type="string">300</item></option>
                <option name="delay500" xsi:type="array"><item name="value" xsi:type="string">500</item><item name="label" xsi:type="string">500</item></option>
            </options></settings></select></formElements>
        </field>
    </fieldset>
</form>
