<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd"
      extends="pagebuilder_base_form">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">pagebuilder_satoshi_hero_slider_form.pagebuilder_satoshi_hero_slider_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Hero slider</item>
    </argument>
    <settings>
        <deps>
            <dep>pagebuilder_satoshi_hero_slider_form.pagebuilder_satoshi_hero_slider_form_data_source</dep>
        </deps>
        <namespace>pagebuilder_satoshi_hero_slider_form</namespace>
    </settings>
    <dataSource name="pagebuilder_satoshi_hero_slider_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_PageBuilder/js/form/provider</item>
            </item>
        </argument>
        <dataProvider name="pagebuilder_satoshi_hero_slider_form_data_source"
                      class="Magento\PageBuilder\Model\ContentType\DataProvider">
            <settings>
                <requestFieldName/>
                <primaryFieldName/>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="appearance_fieldset" sortOrder="10"
              component="Magento_PageBuilder/js/form/element/dependent-fieldset">
        <settings>
            <label translate="true">Appearance</label>
            <additionalClasses>
                <class name="admin__fieldset-visual-select-large">true</class>
            </additionalClasses>
            <collapsible>false</collapsible>
            <opened>true</opened>
            <imports>
                <link name="hideFieldset">${$.name}.appearance:options</link>
                <link name="hideLabel">${$.name}.appearance:options</link>
            </imports>
        </settings>
        <field name="appearance" formElement="select" sortOrder="10"
               component="Magento_PageBuilder/js/form/element/dependent-visual-select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">default</item>
                </item>
            </argument>
            <settings>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                    <class name="admin__field-visual-select-container">true</class>
                </additionalClasses>
                <dataType>text</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <elementTmpl>Magento_PageBuilder/form/element/visual-select</elementTmpl>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="AppearanceSourceSatoshi"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>

    <!-- Réglages globaux du slider -->
    <fieldset name="slider_settings" sortOrder="15">
        <settings>
            <label translate="true">Slider settings</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>

        <!-- Hauteur du slider (ex « Banner height », désormais global) -->
        <field name="slider_height" sortOrder="10" formElement="select"
               component="Magento_PageBuilder/js/form/element/visual-select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">large</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Slider height</label>
                <elementTmpl>Magento_PageBuilder/form/element/visual-select</elementTmpl>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="BlockHeightSource"/>
                    </settings>
                </select>
            </formElements>
        </field>

        <!-- Temps de défilement (autoplay) -->
        <field name="autoplay_speed" sortOrder="20" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">5000</item>
                    <item name="validation" xsi:type="array">
                        <item name="validate-number" xsi:type="boolean">true</item>
                        <item name="validate-digits" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Autoplay speed</label>
                <additionalClasses>
                    <class name="admin__field-small">true</class>
                </additionalClasses>
                <addAfter translate="true">ms</addAfter>
                <notice translate="true">Délai entre deux slides, en millisecondes. 0 = pas de défilement automatique. Ignoré s'il n'y a qu'une slide.</notice>
            </settings>
        </field>

        <!-- Afficher les flèches -->
        <field name="show_arrows" sortOrder="30" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">true</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Show arrows</label>
                <dataScope>show_arrows</dataScope>
                <notice translate="true">Masquées automatiquement s'il n'y a qu'une slide.</notice>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">false</map>
                            <map name="true" xsi:type="string">true</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>

        <!-- Afficher les puces (dots) -->
        <field name="show_dots" sortOrder="40" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">true</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Show dots</label>
                <dataScope>show_dots</dataScope>
                <notice translate="true">Masquées automatiquement s'il n'y a qu'une slide.</notice>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">false</map>
                            <map name="true" xsi:type="string">true</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>

    </fieldset>

    <!-- Slides -->
    <fieldset name="general" sortOrder="20">
        <settings>
            <label translate="true">Slides</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>

        <dynamicRows name="slides" template="Satoshi_SatoshiUi/dynamic-rows/satoshi-hero-slider/default">
            <settings>
                <addButtonLabel translate="true">Add slide</addButtonLabel>
                <dndConfig>
                    <param name="enabled" xsi:type="boolean">true</param>
                    <param name="draggableElementClass" xsi:type="string">_dragged</param>
                    <param name="tableClass" xsi:type="string">table.admin__dynamic-rows</param>
                </dndConfig>
                <additionalClasses>
                    <class name="admin__field-wide">true</class>
                </additionalClasses>
                <componentType>dynamicRows</componentType>
            </settings>
            <container name="record" component="Magento_Ui/js/dynamic-rows/record">
                <argument name="data" xsi:type="array">
                    <item name="config" xsi:type="array">
                        <item name="isTemplate" xsi:type="boolean">true</item>
                        <item name="is_collection" xsi:type="boolean">true</item>
                        <item name="componentType" xsi:type="string">container</item>
                    </item>
                </argument>

                <!-- Type de slide : image ou vidéo (show/hide des champs média) -->
                <field name="slide_type" sortOrder="10" formElement="select">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">image</item>
                            <item name="component" xsi:type="string">Satoshi_SatoshiUi/js/form/hero-slider/slide-type-selector</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Slide type</label>
                        <dataScope>slide_type</dataScope>
                        <validation>
                            <rule name="required-entry" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options>
                                    <option name="0" xsi:type="array">
                                        <item name="value" xsi:type="string">image</item>
                                        <item name="label" xsi:type="string" translate="true">Image</item>
                                    </option>
                                    <option name="1" xsi:type="array">
                                        <item name="value" xsi:type="string">video</item>
                                        <item name="label" xsi:type="string" translate="true">Video</item>
                                    </option>
                                </options>
                            </settings>
                        </select>
                    </formElements>
                </field>

                <!-- ===== Champs IMAGE ===== -->
                <field name="image" sortOrder="20" formElement="imageUploader">
                    <settings>
                        <label translate="true">Desktop image</label>
                        <componentType>imageUploader</componentType>
                        <notice translate="true">Image affichée sur grand écran.</notice>
                    </settings>
                    <formElements>
                        <imageUploader>
                            <settings>
                                <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                                <maxFileSize>4194304</maxFileSize>
                                <uploaderConfig>
                                    <param xsi:type="string" name="url">pagebuilder/contenttype/image_upload</param>
                                </uploaderConfig>
                            </settings>
                        </imageUploader>
                    </formElements>
                </field>

                <field name="mobile_image" sortOrder="30" formElement="imageUploader">
                    <settings>
                        <label translate="true">Mobile image</label>
                        <componentType>imageUploader</componentType>
                        <notice translate="true">Optionnel. Affichée sur petit écran à la place de l'image desktop.</notice>
                    </settings>
                    <formElements>
                        <imageUploader>
                            <settings>
                                <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                                <maxFileSize>4194304</maxFileSize>
                                <uploaderConfig>
                                    <param xsi:type="string" name="url">pagebuilder/contenttype/image_upload</param>
                                </uploaderConfig>
                            </settings>
                        </imageUploader>
                    </formElements>
                </field>

                <!-- ===== Champs VIDÉO (cachés par défaut, slide_type=image) ===== -->
                <field name="video_source" sortOrder="40" formElement="input">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="visible" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Video URL</label>
                        <notice translate="true">Lien YouTube ou Vimeo, ou lien HTTP(S) vers un fichier vidéo (.mp4 recommandé).</notice>
                    </settings>
                </field>

                <field name="video_image" sortOrder="50" formElement="imageUploader">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="visible" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                    <settings>
                        <label translate="true">Video fallback image (desktop)</label>
                        <componentType>imageUploader</componentType>
                        <notice translate="true">Affichée pendant le chargement de la vidéo et en repli.</notice>
                    </settings>
                    <formElements>
                        <imageUploader>
                            <settings>
                                <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                                <maxFileSize>4194304</maxFileSize>
                                <uploaderConfig>
                                    <param xsi:type="string" name="url">pagebuilder/contenttype/image_upload</param>
                                </uploaderConfig>
                            </settings>
                        </imageUploader>
                    </formElements>
                </field>

                <field name="video_mobile_image" sortOrder="60" formElement="imageUploader">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="visible" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                    <settings>
                        <label translate="true">Video fallback image (mobile)</label>
                        <componentType>imageUploader</componentType>
                        <notice translate="true">Optionnel. Repli vidéo sur petit écran.</notice>
                    </settings>
                    <formElements>
                        <imageUploader>
                            <settings>
                                <allowedExtensions>jpg jpeg gif png webp</allowedExtensions>
                                <maxFileSize>4194304</maxFileSize>
                                <uploaderConfig>
                                    <param xsi:type="string" name="url">pagebuilder/contenttype/image_upload</param>
                                </uploaderConfig>
                            </settings>
                        </imageUploader>
                    </formElements>
                </field>

                <field name="autoplay" sortOrder="70" formElement="checkbox">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">true</item>
                            <item name="visible" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>boolean</dataType>
                        <label translate="true">Autoplay</label>
                        <dataScope>autoplay</dataScope>
                        <notice translate="true">L'autoplay nécessite que la vidéo soit muette.</notice>
                    </settings>
                    <formElements>
                        <checkbox>
                            <settings>
                                <valueMap>
                                    <map name="false" xsi:type="string">false</map>
                                    <map name="true" xsi:type="string">true</map>
                                </valueMap>
                                <prefer>toggle</prefer>
                            </settings>
                        </checkbox>
                    </formElements>
                </field>

                <field name="loop" sortOrder="80" formElement="checkbox">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">true</item>
                            <item name="visible" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>boolean</dataType>
                        <label translate="true">Loop video</label>
                        <dataScope>loop</dataScope>
                    </settings>
                    <formElements>
                        <checkbox>
                            <settings>
                                <valueMap>
                                    <map name="false" xsi:type="string">false</map>
                                    <map name="true" xsi:type="string">true</map>
                                </valueMap>
                                <prefer>toggle</prefer>
                            </settings>
                        </checkbox>
                    </formElements>
                </field>

                <field name="muted" sortOrder="90" formElement="checkbox">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">true</item>
                            <item name="visible" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>boolean</dataType>
                        <label translate="true">Mute video</label>
                        <dataScope>muted</dataScope>
                    </settings>
                    <formElements>
                        <checkbox>
                            <settings>
                                <valueMap>
                                    <map name="false" xsi:type="string">false</map>
                                    <map name="true" xsi:type="string">true</map>
                                </valueMap>
                                <prefer>toggle</prefer>
                            </settings>
                        </checkbox>
                    </formElements>
                </field>

                <!-- ===== Champs communs ===== -->
                <field name="heading" sortOrder="100" formElement="input">
                    <settings>
                        <label translate="true">Heading</label>
                        <dataType>text</dataType>
                        <validation>
                            <rule name="validate-string" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                </field>

                <field name="description" sortOrder="110" formElement="textarea">
                    <settings>
                        <label translate="true">Description</label>
                        <dataType>text</dataType>
                        <validation>
                            <rule name="validate-string" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                </field>

                <field name="button_label" sortOrder="120" formElement="input">
                    <settings>
                        <label translate="true">Button label</label>
                        <dataType>text</dataType>
                        <validation>
                            <rule name="validate-no-html-tags" xsi:type="boolean">true</rule>
                        </validation>
                    </settings>
                </field>

                <field name="button_link" sortOrder="130" formElement="input">
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Button link</label>
                        <notice translate="true">URL du bouton (relative ou absolue).</notice>
                    </settings>
                </field>

                <field name="button_target" sortOrder="135" formElement="checkbox">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">false</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>boolean</dataType>
                        <label translate="true">Open in new tab</label>
                        <dataScope>button_target</dataScope>
                    </settings>
                    <formElements>
                        <checkbox>
                            <settings>
                                <valueMap>
                                    <map name="false" xsi:type="string">false</map>
                                    <map name="true" xsi:type="string">true</map>
                                </valueMap>
                                <prefer>toggle</prefer>
                            </settings>
                        </checkbox>
                    </formElements>
                </field>

                <field name="button_style" sortOrder="137" formElement="select">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">filled</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Button style</label>
                        <notice translate="true">La couleur du bouton est déduite du « Text color scheme ».</notice>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options>
                                    <option name="0" xsi:type="array">
                                        <item name="value" xsi:type="string">filled</item>
                                        <item name="label" xsi:type="string" translate="true">Plein (filled)</item>
                                    </option>
                                    <option name="1" xsi:type="array">
                                        <item name="value" xsi:type="string">outlined</item>
                                        <item name="label" xsi:type="string" translate="true">Contour (outlined)</item>
                                    </option>
                                </options>
                            </settings>
                        </select>
                    </formElements>
                </field>

                <field name="text_color_scheme" sortOrder="140" formElement="select">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">inverse</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Text color scheme</label>
                        <notice translate="true">« Inversé » = textes/boutons clairs (média sombre) ; « Par défaut » = textes qui suivent le fond.</notice>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options>
                                    <option name="0" xsi:type="array">
                                        <item name="value" xsi:type="string">default</item>
                                        <item name="label" xsi:type="string" translate="true">Par défaut — texte qui suit le fond</item>
                                    </option>
                                    <option name="1" xsi:type="array">
                                        <item name="value" xsi:type="string">inverse</item>
                                        <item name="label" xsi:type="string" translate="true">Inversé — texte sur média contrastant</item>
                                    </option>
                                </options>
                            </settings>
                        </select>
                    </formElements>
                </field>

                <field name="desktop_content_position" sortOrder="150" formElement="select">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">middle-center</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Desktop content position</label>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options>
                                    <option name="0" xsi:type="array"><item name="value" xsi:type="string">top-left</item><item name="label" xsi:type="string" translate="true">Top Left</item></option>
                                    <option name="1" xsi:type="array"><item name="value" xsi:type="string">top-center</item><item name="label" xsi:type="string" translate="true">Top Center</item></option>
                                    <option name="2" xsi:type="array"><item name="value" xsi:type="string">top-right</item><item name="label" xsi:type="string" translate="true">Top Right</item></option>
                                    <option name="3" xsi:type="array"><item name="value" xsi:type="string">middle-left</item><item name="label" xsi:type="string" translate="true">Middle Left</item></option>
                                    <option name="4" xsi:type="array"><item name="value" xsi:type="string">middle-center</item><item name="label" xsi:type="string" translate="true">Middle Center</item></option>
                                    <option name="5" xsi:type="array"><item name="value" xsi:type="string">middle-right</item><item name="label" xsi:type="string" translate="true">Middle Right</item></option>
                                    <option name="6" xsi:type="array"><item name="value" xsi:type="string">bottom-left</item><item name="label" xsi:type="string" translate="true">Bottom Left</item></option>
                                    <option name="7" xsi:type="array"><item name="value" xsi:type="string">bottom-center</item><item name="label" xsi:type="string" translate="true">Bottom Center</item></option>
                                    <option name="8" xsi:type="array"><item name="value" xsi:type="string">bottom-right</item><item name="label" xsi:type="string" translate="true">Bottom Right</item></option>
                                </options>
                            </settings>
                        </select>
                    </formElements>
                </field>

                <field name="mobile_content_position" sortOrder="160" formElement="select">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">middle-center</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>text</dataType>
                        <label translate="true">Mobile content position</label>
                    </settings>
                    <formElements>
                        <select>
                            <settings>
                                <options>
                                    <option name="0" xsi:type="array"><item name="value" xsi:type="string">top-left</item><item name="label" xsi:type="string" translate="true">Top Left</item></option>
                                    <option name="1" xsi:type="array"><item name="value" xsi:type="string">top-center</item><item name="label" xsi:type="string" translate="true">Top Center</item></option>
                                    <option name="2" xsi:type="array"><item name="value" xsi:type="string">top-right</item><item name="label" xsi:type="string" translate="true">Top Right</item></option>
                                    <option name="3" xsi:type="array"><item name="value" xsi:type="string">middle-left</item><item name="label" xsi:type="string" translate="true">Middle Left</item></option>
                                    <option name="4" xsi:type="array"><item name="value" xsi:type="string">middle-center</item><item name="label" xsi:type="string" translate="true">Middle Center</item></option>
                                    <option name="5" xsi:type="array"><item name="value" xsi:type="string">middle-right</item><item name="label" xsi:type="string" translate="true">Middle Right</item></option>
                                    <option name="6" xsi:type="array"><item name="value" xsi:type="string">bottom-left</item><item name="label" xsi:type="string" translate="true">Bottom Left</item></option>
                                    <option name="7" xsi:type="array"><item name="value" xsi:type="string">bottom-center</item><item name="label" xsi:type="string" translate="true">Bottom Center</item></option>
                                    <option name="8" xsi:type="array"><item name="value" xsi:type="string">bottom-right</item><item name="label" xsi:type="string" translate="true">Bottom Right</item></option>
                                </options>
                            </settings>
                        </select>
                    </formElements>
                </field>

                <field name="overlay_opacity" sortOrder="170" formElement="input">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="default" xsi:type="string">40</item>
                            <item name="validation" xsi:type="array">
                                <item name="required-entry" xsi:type="boolean">true</item>
                                <item name="validate-number" xsi:type="boolean">true</item>
                                <item name="validate-number-range" xsi:type="string">0-100</item>
                            </item>
                        </item>
                    </argument>
                    <settings>
                        <label translate="true">Overlay opacity</label>
                        <additionalClasses>
                            <class name="admin__field-small">true</class>
                        </additionalClasses>
                        <addAfter translate="true">%</addAfter>
                        <notice translate="true">Entre 0 et 100</notice>
                    </settings>
                </field>

                <actionDelete template="Magento_Backend/dynamic-rows/cells/action-delete">
                    <argument name="data" xsi:type="array">
                        <item name="config" xsi:type="array">
                            <item name="fit" xsi:type="boolean">false</item>
                        </item>
                    </argument>
                    <settings>
                        <dataType>text</dataType>
                        <label>Delete</label>
                        <componentType>actionDelete</componentType>
                    </settings>
                </actionDelete>
            </container>
        </dynamicRows>
    </fieldset>

    <fieldset name="advanced">
        <field name="text_align">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">center</item>
                    <item name="visible" xsi:type="boolean">false</item>
                </item>
            </argument>
        </field>
    </fieldset>
</form>
