<?php

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use Pdb\ThemeHyva\ViewModel\IconRenderer;
use Satoshi\SatoshiUi\Helper\Decode as DecodeHelper;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var IconRenderer $iconRenderer */
$iconRenderer = $viewModels->require(IconRenderer::class);

/** @var DecodeHelper $decodeHelper */
$decodeHelper = $this->helper(DecodeHelper::class);
$guarantees = $block->getData('guarantees');
$guarantees = $decodeHelper->decodeJSONHTMLEntity($guarantees);

// Style options (onglet "Style" du Page Builder). Valeurs vides => fallback tokens.
$iconStyle  = is_string($block->getData('icon_style') ?? null) ? $block->getData('icon_style') : '';
$iconSize   = is_string($block->getData('icon_size') ?? null) ? $block->getData('icon_size') : '';
$layout     = is_string($block->getData('item_layout') ?? null) ? $block->getData('item_layout') : '';
$iconColorRaw   = is_string($block->getData('icon_color') ?? null) ? trim($block->getData('icon_color')) : '';
$circleColorRaw = is_string($block->getData('circle_color') ?? null) ? trim($block->getData('circle_color')) : '';

// Resout une valeur de couleur : token design system (--color-x) => var(...) avec
// repli currentColor ; ou valeur hex heritee ; sinon vide (=> fallback tokens).
$resolveColor = static function (string $value): string {
    if (preg_match('/^--[a-z0-9-]+$/i', $value)) {
        return 'var(' . $value . ', currentColor)';
    }
    if (preg_match('/^#[0-9a-fA-F]{3,8}$/', $value)) {
        return $value;
    }
    return '';
};

$iconColor   = $resolveColor($iconColorRaw);
$circleColor = $resolveColor($circleColorRaw);

if (!in_array($iconStyle, ['bordered', 'filled', 'bare'], true)) {
    $iconStyle = 'bordered';
}
if (!in_array($iconSize, ['small', 'medium', 'large'], true)) {
    $iconSize = 'medium';
}
if (!in_array($layout, ['stacked', 'inline'], true)) {
    $layout = 'stacked';
}

// Taille : padding du cercle, classes & dimensions de l'icône.
$sizeMap = [
    'small'  => ['pad' => 'p-4', 'icon' => 'h-6 w-6', 'dim' => 24],
    'medium' => ['pad' => 'p-6', 'icon' => 'h-7 w-7', 'dim' => 24],
    'large'  => ['pad' => 'p-6', 'icon' => 'h-10 w-10', 'dim' => 32],
];
$iconPad  = $sizeMap[$iconSize]['pad'];
$iconDim  = $sizeMap[$iconSize]['dim'];
$iconSizeClass = $sizeMap[$iconSize]['icon'];

// Classes / styles du contour autour de l'icône selon le style choisi.
$wrapperClasses = '';
$wrapperStyle   = '';
if ($iconStyle === 'bordered') {
    $wrapperClasses = 'w-fit rounded-full border ' . $iconPad;
    $wrapperStyle = $circleColor !== ''
        ? 'border-color:' . $circleColor . ';'
        : '';
    if ($circleColor === '') {
        $wrapperClasses .= ' border-primary-lighter';
    }
} elseif ($iconStyle === 'filled') {
    $wrapperClasses = 'w-fit rounded-full ' . $iconPad;
    $wrapperStyle = $circleColor !== ''
        ? 'background-color:' . $circleColor . ';'
        : '';
    if ($circleColor === '') {
        $wrapperClasses .= ' bg-primary-lighter';
    }
}

// Couleur de l'icône : style inline si défini, sinon token text-fg.
$iconClasses = $iconSizeClass . ($iconColor === '' ? ' text-fg' : '');
$iconAttributes = ['aria-hidden' => 'true'];
if ($iconColor !== '') {
    $iconAttributes['style'] = 'color:' . $iconColor;
}

// Schéma de couleur du texte : "light" (textes clairs, fond sombre) ou "dark"
// (textes sombres, fond clair — défaut). On conserve la nuance titre/description :
// titre = couleur principale, description = couleur atténuée.
// Scheme porté par data-scheme="dark" sur la racine ; titre = text-fg,
// description = text-fg-secondary (remappés en CSS, color-scheme.css).
$colorScheme = $block->getData('text_color_scheme') === 'inverse' ? 'inverse' : 'default';
$titleColor = 'text-fg';
$descColor  = 'text-fg-secondary';
$schemeAttr = $colorScheme === 'inverse';

// Agencement : icône au-dessus (stacked) ou icône à gauche (inline).
if ($layout === 'inline') {
    $itemClasses    = 'flex flex-row items-center justify-start gap-4 max-md:w-full md:flex-shrink-0';
    $textWrapClasses = 'flex flex-col gap-1 text-left';
    $titleClasses    = 'text-lg ' . $titleColor . ' m-0';
} else {
    $itemClasses    = 'flex flex-col items-center justify-start gap-7 max-md:w-full md:flex-shrink-0';
    $textWrapClasses = 'flex flex-col gap-4 text-center';
    $titleClasses    = 'text-lg ' . $titleColor . ' m-0 md:whitespace-nowrap';
}
?>
<?php if ($guarantees): ?>
    <div class="relative flex flex-col gap-8 md:grid md:grid-cols-4 md:gap-14"<?php if ($schemeAttr): ?> data-scheme="dark"<?php endif; ?>>
        <?php foreach ($guarantees as $guarantee): ?>
            <?php
            // Lien optionnel : si une URL est renseignee, toute la colonne devient
            // cliquable (<a>), sinon on conserve un simple <div>. URL absolue ou
            // relative (saisie libre cote BO).
            $linkHref   = is_string($guarantee['column_link'] ?? null) ? trim($guarantee['column_link']) : '';
            $newTab     = !empty($guarantee['column_link_new_tab'])
                && !in_array($guarantee['column_link_new_tab'], ['0', 'false', ''], true);
            $itemTag    = $linkHref !== '' ? 'a' : 'div';
            ?>
            <<?= $itemTag ?> class="<?= $escaper->escapeHtmlAttr($itemClasses) ?>"
                <?php if ($linkHref !== ''): ?>
                    href="<?= $escaper->escapeUrl($linkHref) ?>"
                    <?php if ($newTab): ?>target="_blank" rel="noopener"<?php endif; ?>
                <?php endif; ?>>
                <?php $columnIcon = is_string($guarantee['column_icon'] ?? null) ? $guarantee['column_icon'] : ''; ?>
                <?php if ($iconStyle === 'bare'): ?>
                    <?php if ($columnIcon !== ''): ?>
                        <?= /* @noEscape */ $iconRenderer->renderHtml(
                            $columnIcon,
                            $iconClasses,
                            $iconDim,
                            $iconDim,
                            $iconAttributes
                        ) ?>
                    <?php endif; ?>
                <?php else: ?>
                <div class="<?= $escaper->escapeHtmlAttr($wrapperClasses) ?>"
                    <?php if ($wrapperStyle !== ''): ?>style="<?= $escaper->escapeHtmlAttr($wrapperStyle) ?>"<?php endif; ?>>
                    <?php if ($columnIcon !== ''): ?>
                        <?= /* @noEscape */ $iconRenderer->renderHtml(
                            $columnIcon,
                            $iconClasses,
                            $iconDim,
                            $iconDim,
                            $iconAttributes
                        ) ?>
                    <?php endif; ?>
                </div>
                <?php endif; ?>
                <div class="<?= $escaper->escapeHtmlAttr($textWrapClasses) ?>">
                    <h3 class="<?= $escaper->escapeHtmlAttr($titleClasses) ?>">
                        <?= $escaper->escapeHtml($guarantee['column_title']) ?>
                    </h3>
                    <p class="m-0 <?= $escaper->escapeHtmlAttr($descColor) ?>">
                        <?= $escaper->escapeHtml($guarantee['column_description']) ?>
                    </p>
                </div>
            </<?= $itemTag ?>>
        <?php endforeach; ?>
    </div>
<?php endif; ?>
