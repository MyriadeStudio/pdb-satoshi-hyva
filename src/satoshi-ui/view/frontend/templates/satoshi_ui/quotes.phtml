<?php

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\SvgIcons;
use Magento\Framework\Escaper;
use Satoshi\SatoshiUi\Block\Quotes;
use Satoshi\SatoshiUi\Helper\Decode as DecodeHelper;
use Satoshi\Theme\Block\Template;

/** @var Quotes $block */
/** @var Template $template */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var SvgIcons $hyvaicons */
$hyvaicons = $viewModels->require(SvgIcons::class);

/** @var DecodeHelper $decodeHelper */
$decodeHelper = $this->helper(DecodeHelper::class);
$quotes = $block->getData('quotes');
$quotes = $decodeHelper->decodeJSONHTMLEntity($quotes);
$id = uniqid();

// Schéma de couleur du texte (onglet Style) : "light" = textes clairs (fond
// sombre), "dark" = textes sombres (fond clair, défaut). S'applique au titre,
// aux citations et aux auteurs ; les étoiles de note gardent leur couleur.
// Le scheme est porté par data-scheme="dark" sur le conteneur racine ; le texte
// utilise l'utilitaire sémantique text-fg, remappé en CSS (color-scheme.css).
$colorScheme = $block->getData('text_color_scheme') === 'inverse' ? 'inverse' : 'default';
$textColor = 'text-fg';
$schemeAttr = $colorScheme === 'inverse';

$slidesHtml = '';
foreach ($quotes as $quote) {
    $rate = floatval($quote['rate']);
    $starsHtml = array_reduce(range(0, 4), function ($carry, $item) use ($rate, $hyvaicons, $textColor) {
        // Do full stars
        $full = floor($rate);
        if ($item < $full) {
            return $carry . $hyvaicons->renderHtml('star-full', $textColor);
        } elseif($full != $rate && $item == $full) {
            return $carry . $hyvaicons->renderHtml('star-half', $textColor);
        } else {
            return $carry . $hyvaicons->renderHtml('star-empty', $textColor);
        }
    });
    $slidesHtml .= <<<HTML
        <div class="slider__slide">
            <div>
                <div class="flex gap-2 text-xl mb-5">
                    $starsHtml
                </div>
                <div class="rte mb-5 text-lg {$textColor} md:text-2xl">{$quote['quote']}</div>
                <span class="{$textColor}">– {$quote['author_name']}</span>
            </div>
        </div>
    HTML;
}
?>
<div<?php if ($schemeAttr): ?> data-scheme="dark"<?php endif; ?>>
    <div
        class="px-7 py-8 md:p-12"
        x-data="Slider()"
    >
        <div class="mb-7 flex w-full items-center justify-between md:mb-8">
            <h2 class="heading <?= $escaper->escapeHtmlAttr($textColor) ?>">
                <?= $escaper->escapeHtml($block->getData('heading')) ?>
            </h2>
            <?php if (count($quotes) > 1): ?>
                <div class="min-h-9">
                    <div x-show="!isPrevBtnDisabled || !isNextBtnDisabled"
                         class="whitespace-nowrap"
                         x-transition
                         x-cloak
                    >
                        <?= $template->render('Magento_Catalog::html/slider-buttons.phtml') ?>
                    </div>
                </div>
            <?php endif; ?>
        </div>

        <?= $template
            ->setData([
                'slides' => $slidesHtml,
                'gap' => 16,
                'slides_amount_in_view' => ['xs' => 1, 'sm' => 1, 'md' => 1, 'lg' => 1, 'xl' => 1, 'xxl' => 1],
                'is_custom_slider_x_data' => true,
                'is_header_disabled' => true,
                'is_scrollbar_hidden' => true
            ])
            ->render('Magento_Catalog::html/slider.phtml'); ?>
    </div>
</div>
